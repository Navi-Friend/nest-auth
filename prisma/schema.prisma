// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  generatedFileExtension = "ts"
  moduleFormat           = "cjs"
  importFileExtension    = ""
}

datasource db {
  provider = "postgresql"
}

